rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny Catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PHASE 3: PRIMITIVE DEFINITIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Identify ownership by tenantId
    function isOwner(data) {
      return isSignedIn() && data.tenantId == request.auth.uid;
    }

    // --- PHASE 4: DRAFTING THE FORTRESS RULES ---

    match /records/{recordId} {
      // Global constraint: Every record must have a type and belong to the authenticated user's tenant
      function isValidBase(data) {
        return data.keys().hasAll(['type', 'tenantId', 'id']) &&
               data.tenantId == request.auth.uid &&
               data.id == recordId;
      }

      // --- Entity Validation Blueprints ---

      function isValidTenant(data) {
        return data.type == 'tenant' &&
               data.name is string && data.name.size() >= 2 && data.name.size() <= 100 &&
               data.location is string && data.location.size() <= 200;
      }

      function isValidPart(data) {
        return data.type == 'part' &&
               data.name is string && data.name.size() >= 2 && data.name.size() <= 150 &&
               data.sku is string && data.sku.size() <= 50 &&
               data.category is string &&
               data.brand is string &&
               data.price is number && data.price >= 0 &&
               data.quantity is int && data.quantity >= 0 &&
               data.lastUpdated is string; // Simplified for MVP
      }

      function isValidCustomer(data) {
        return data.type == 'customer' &&
               data.name is string && data.name.size() >= 2 && data.name.size() <= 100 &&
               data.phone is string && data.phone.size() >= 7 && data.phone.size() <= 20 &&
               data.totalSpent is number && data.totalSpent >= 0;
      }

      function isValidInvoice(data) {
        return data.type == 'invoice' &&
               data.invoiceNumber is string &&
               data.customerId is string &&
               data.total is number && data.total >= 0 &&
               data.status in ['Paid', 'Pending', 'Cancelled'];
      }

      // --- CRUD Operations ---

      allow create: if isVerified() && isValidId(recordId) && isValidBase(incoming()) && (
        isValidTenant(incoming()) ||
        isValidPart(incoming()) ||
        isValidCustomer(incoming()) ||
        isValidInvoice(incoming())
      );

      allow update: if isVerified() && isOwner(existing()) && isValidBase(incoming()) && (
        incoming().type == existing().type && (
          (existing().type == 'tenant' && isValidTenant(incoming())) ||
          (existing().type == 'part' && isValidPart(incoming())) ||
          (existing().type == 'customer' && isValidCustomer(incoming())) ||
          (existing().type == 'invoice' && isValidInvoice(incoming()))
        )
      );

      // Secure list and get: enforcing tenant boundary
      allow read: if isSignedIn() && existing().tenantId == request.auth.uid;
      
      allow delete: if isVerified() && isOwner(existing());
    }
  }
}
